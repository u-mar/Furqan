# HuggingFace Inference API token (free tier works for MVP)
# Get one at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_...

# Base URL for Quran Foundation API — no auth needed
QURAN_API_BASE=https://api.quran.com/api/v4

# Optional: LAN / phone testing — comma-separated hosts Next.js may block in dev
# Example: ALLOWED_DEV_ORIGINS=192.168.1.34,10.0.0.5
ALLOWED_DEV_ORIGINS=192.168.1.34

# Somali voice translation MP3s (production CDN). Timings live in public/data/somali-voice/manifest.json
# Example: https://your-bucket.r2.dev/somali-v1  (put chunk-07.mp3 etc. there)
# Leave unset for local dev → MP3s in public/data/somali-voice/audio/
# NEXT_PUBLIC_SOMALI_VOICE_CDN_URL=
